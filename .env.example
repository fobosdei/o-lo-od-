# ╔═══════════════════════════════════════════════════════╗
# ║  VAULT — Environment Variables                        ║
# ║  Copia este archivo a .env y rellena tus valores      ║
# ╚═══════════════════════════════════════════════════════╝

# ─── Frontend (Vite) ──────────────────────────────────────
# Supabase project URL (from Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co

# Supabase anon/public key (safe to expose in frontend with RLS)
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui

# Backend URL for API calls
# En producción usa 127.0.0.1, en desarrollo localhost
VITE_API_URL=http://localhost:4000

# ─── Backend (Express) ────────────────────────────────────
# Same Supabase URL
SUPABASE_URL=https://TU_PROJECT_ID.supabase.co

# Supabase service role key (SECRETO — solo para el backend)
# Encuéntralo en: Supabase → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreto_aqui

# Puerto del backend local
BACKEND_PORT=4000

# Entorno (development | production)
NODE_ENV=development

# JWT secret para tokens adicionales (genera uno aleatorio)
JWT_SECRET=genera_un_string_aleatorio_de_64_caracteres_aqui

# ─── Seguridad ────────────────────────────────────────────
# Tiempo de inactividad en minutos antes de auto-lock
VITE_INACTIVITY_TIMEOUT=5
